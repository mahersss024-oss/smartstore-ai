# Application
NODE_ENV=development
DEMO_MODE=false
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_LOGGING_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/postgres
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=10000
DATABASE_IDLE_TIMEOUT_MS=30000

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_WEBHOOK_SIGNING_SECRET=whsec_replace_me
PLATFORM_ADMIN_USER_IDS=user_replace_me

# Platform secret encryption root. Keep in Vercel; do not expose in admin UI.
PLATFORM_SECRETS_ENCRYPTION_KEY=replace_with_at_least_32_random_characters
# During rotation, keep older roots here as a comma-separated decrypt-only keyring.
PLATFORM_SECRETS_PREVIOUS_ENCRYPTION_KEYS=

# Platform AI inbound integration
AI_EMPLOYEE_WEBHOOK_SECRET=replace_with_a_long_random_secret

# Twilio Verify credentials used only for web customer phone verification (OTP).
# WhatsApp credentials are stored encrypted per store from the store settings page.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
# Create a Verify Service at console.twilio.com/us1/verify/services
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Protected scheduled maintenance endpoint
MAINTENANCE_SECRET=replace_with_at_least_32_random_characters

# Optional post-launch Stripe platform billing
# Leave unset while automated platform billing is outside the active launch scope.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_STARTER_MONTHLY=price_replace_me
STRIPE_PRICE_GROWTH_MONTHLY=price_replace_me
STRIPE_PRICE_PRO_MONTHLY=price_replace_me
STRIPE_PRICE_EXTRA_AI_ORDERS=price_replace_me
STRIPE_PRICE_EXTRA_CATALOG_ITEMS=price_replace_me
STRIPE_PRICE_EXTRA_IMAGE_STORAGE=price_replace_me
STRIPE_PRICE_EXTRA_TEAM_MEMBER=price_replace_me

# Optional post-launch customer payment provider
# Keep unset while customer online payments are outside the active launch scope.
MOYASAR_SECRET_KEY=

# Optional post-launch external log forwarding
# The application continues to log to the runtime console when these are unset.
BETTER_STACK_SOURCE_TOKEN=
BETTER_STACK_INGESTING_HOST=

# Optional monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORGANIZATION=
SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_DISABLED=true

# Optional remote product image hosts, comma-separated and HTTPS only
NEXT_IMAGE_REMOTE_HOSTS=
