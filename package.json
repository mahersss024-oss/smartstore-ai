{
  "name": "smartstore-ai",
  "author": "Maher Alhafithi",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev:spotlight": "npx @spotlightjs/spotlight",
    "dev:next": "next dev",
    "dev": "run-p db-server:file dev:next",
    "dev:with-spotlight": "cross-env NEXT_PUBLIC_SENTRY_SPOTLIGHT=true run-p db-server:file dev:next dev:spotlight",
    "build:next": "next build",
    "build-local": "run-p db-server:memory build:next --race",
    "build": "npm run build:next",
    "build:with-migrate": "run-s db:migrate build:next",
    "start": "next start",
    "build-stats": "cross-env ANALYZE=true npm run build",
    "clean": "rimraf .next .next-dev out coverage",
    "clean:dev": "rimraf .next-dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:types": "tsc --noEmit --pretty",
    "type-check": "npm run check:types",
    "check:deps": "knip",
    "check:i18n": "i18n-check -l src/locales -s ar -u src -f next-intl",
    "check:env:production": "node scripts/validate-production-env.mjs",
    "check:runtime:production": "node scripts/check-production-runtime.mjs",
    "maintenance:whapi-renewals": "node scripts/run-whapi-renewals.mjs",
    "smoke:production": "node scripts/smoke-test-production.mjs",
    "load:production:read-only": "node scripts/load-test-production.mjs",
    "verify:diff": "git diff --check",
    "verify:code": "run-s check:types lint test check:i18n check:deps verify:diff build test:e2e",
    "commit": "commit",
    "test": "cross-env NODE_OPTIONS=--disable-warning=DEP0205 vitest run",
    "test:coverage": "npm test -- --coverage --coverage.reporter=text --coverage.reporter=json-summary",
    "test:e2e": "cross-env PORT=3010 DB_PORT=5440 NODE_OPTIONS=--disable-warning=DEP0205 playwright test",
    "test:e2e:default-db-port": "cross-env NODE_OPTIONS=--disable-warning=DEP0205 playwright test",
    "db-server:file": "pglite-server -m 100 --port=5433 --db=local-5433.db",
    "db-server:memory": "pglite-server -m 100 --port=5433",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -c -- drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "storybook": "storybook dev -p 6006",
    "storybook:test": "vitest run --config .storybook/vitest.config.ts",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@clerk/localizations": "^4.6.7",
    "@clerk/nextjs": "^7.4.0",
    "@clerk/ui": "^1.13.0",
    "@logtape/logtape": "^2.1.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.53.1",
    "@solana/web3.js": "^1.98.4",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@upstash/qstash": "^2.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-intl": "^4.12.0",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@chromatic-com/playwright": "^0.14.10",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/prompt-cli": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "@electric-sql/pglite": "^0.4.5",
    "@electric-sql/pglite-socket": "^0.1.5",
    "@eslint-react/eslint-plugin": "^5.8.4",
    "@lingual/i18n-check": "^0.9.5",
    "@next/bundle-analyzer": "^16.2.6",
    "@next/eslint-plugin-next": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@spotlightjs/spotlight": "^4.11.4",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/nextjs-vite": "^10.4.6",
    "@swc/helpers": "^0.5.21",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "checkly": "^8.8.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.4.6",
    "knip": "^6.14.2",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "vitest-browser-react": "^2.2.0"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/github"
    ]
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "jayson": {
      "uuid": "^11.1.1"
    },
    "postcss": "^8.5.15",
    "storybook": "^10.4.6"
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  }
}
